rules_version = '2';

// Each signed-in user can read and write only the data under their own
// users/{uid} tree — their profile, their cats, and each cat's documents.
// Everything outside that (and every unauthenticated request) is denied by the
// default-deny behaviour, so no one can reach another person's data.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Explicit catch-all deny: nothing outside a user's own tree is reachable,
    // by anyone, authenticated or not.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
