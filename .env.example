# Copy this file to .env and fill in real values. .env is gitignored.

# Firebase (from your Firebase project settings)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

FIREBASE_APP_ID_WEB=your_web_app_id
FIREBASE_APP_ID_ANDROID=your_android_app_id
FIREBASE_APP_ID_IOS=your_ios_app_id
FIREBASE_APP_ID_MACOS=your_macos_app_id
FIREBASE_APP_ID_WINDOWS=your_windows_app_id

# Hack Club AI key for the assistant tab — get one at https://ai.hackclub.com/dashboard
HACKCLUB_API_KEY=replace_with_your_hackclub_api_key

# Optional AI overrides — sensible defaults are baked in; uncomment only to override.
# AI_BASE_URL defaults to the Hack Club OpenAI-compatible proxy.
# AI_MODEL defaults to google/gemini-3-flash-preview (the app's chosen model).
# AI_API_KEY is an alternate to HACKCLUB_API_KEY for a different OpenAI-compatible backend.
# AI_BASE_URL=https://ai.hackclub.com/proxy/v1
# AI_MODEL=google/gemini-3-flash-preview
# AI_API_KEY=
