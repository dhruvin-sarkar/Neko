<?xml version="1.0" encoding="utf-8"?>
<!-- Neko Notch system notification (Layer 2). RemoteViews is populated by
     NekoLiveActivityManager.buildNotification(). Ids are referenced there. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FF000000"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/neko_cat_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginEnd="12dp"
        android:contentDescription="Neko" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/neko_primary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Neko" />

        <TextView
            android:id="@+id/neko_secondary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFABABAB"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />

    </LinearLayout>

    <ImageView
        android:id="@+id/neko_action_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:visibility="gone"
        android:contentDescription="@null" />

</LinearLayout>
